APP_DATABASE_URL=jdbc:postgresql://aws-0-YOUR-REGION.pooler.supabase.com:5432/postgres?sslmode=require
APP_DATABASE_USERNAME=postgres.YOUR_SUPABASE_PROJECT_REF
APP_DATABASE_PASSWORD=your_database_password

TWELVEDATA_API_KEY=your_twelvedata_api_key

MARKETDATA_API_DAILY_CALL_LIMIT=800
MARKETDATA_API_TIMEZONE=America/Toronto
MARKETDATA_REFRESH_DELAY_MS=120000
MARKETDATA_REFRESH_INITIAL_DELAY_MS=10000
PORT=8080
APP_CORS_ALLOWED_ORIGINS=http://localhost:5173,https://your-frontend-domain.com
